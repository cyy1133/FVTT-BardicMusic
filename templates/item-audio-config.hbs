<form class="{{cssClass}} flexcol bardic-music-form" autocomplete="off">
  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Enable"}}</label>
    <div class="form-fields">
      <input type="checkbox" name="enabled" {{checked config.enabled}}>
    </div>
  </div>

  <div class="form-group stacked">
    <label>{{localize "BARDSONG.Config.Source"}}</label>
    <div class="form-fields">
      <input type="text" name="src" value="{{config.src}}" placeholder="sounds/music/theme.ogg">
      <button type="button" class="bardic-file-picker">
        <i class="fas fa-folder-open"></i>
        {{localize "BARDSONG.Config.Picker"}}
      </button>
    </div>
    <p class="hint">{{localize "BARDSONG.Config.SourceHint"}}</p>
  </div>

  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Trigger"}}</label>
    <div class="form-fields">
      <select name="trigger">
        {{#each triggerOptions as |label value|}}
        <option value="{{value}}" {{#if (eq ../config.trigger value)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Behavior"}}</label>
    <div class="form-fields">
      <select name="behavior">
        {{#each behaviorOptions as |label value|}}
        <option value="{{value}}" {{#if (eq ../config.behavior value)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Audience"}}</label>
    <div class="form-fields">
      <select name="audience">
        {{#each audienceOptions as |label value|}}
        <option value="{{value}}" {{#if (eq ../config.audience value)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Channel"}}</label>
    <div class="form-fields">
      <select name="channel">
        {{#each channelOptions as |label value|}}
        <option value="{{value}}" {{#if (eq ../config.channel value)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Volume"}}</label>
    <div class="form-fields">
      <input type="range" name="volume" min="0" max="1" step="0.05" value="{{config.volume}}">
      <span class="range-value" data-volume-display>{{volumeLabel}}</span>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Loop"}}</label>
    <div class="form-fields">
      <input type="checkbox" name="loop" {{checked config.loop}}>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "BARDSONG.Config.Fade"}}</label>
    <div class="form-fields">
      <input type="number" name="fade" min="0" step="50" value="{{config.fade}}">
    </div>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="button" class="bardic-preview">
      <i class="fas fa-play"></i>
      {{localize "BARDSONG.Config.Preview"}}
    </button>
    <button type="submit" name="submit">
      <i class="far fa-save"></i>
      {{localize "Save Changes"}}
    </button>
  </footer>
</form>
